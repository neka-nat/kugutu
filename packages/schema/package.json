{
  "name": "@kugutu/schema",
  "version": "0.1.0",
  "description": "Character schema, slot taxonomy, behavior specs, and validation for Kugutu.",
  "keywords": [
    "kugutu",
    "character",
    "avatar",
    "mascot",
    "animation",
    "svg",
    "2d",
    "schema"
  ],
  "license": "MIT",
  "author": "neka-nat <nekanat.stock@gmail.com>",
  "homepage": "https://github.com/neka-nat/kugutu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neka-nat/kugutu.git",
    "directory": "packages/schema"
  },
  "bugs": "https://github.com/neka-nat/kugutu/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./character.schema.json": "./character.schema.json",
    "./charbundle.schema.json": "./charbundle.schema.json"
  },
  "files": [
    "dist",
    "character.schema.json",
    "charbundle.schema.json",
    "examples"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  }
}
