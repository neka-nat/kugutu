{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kugutu.dev/schema/character.schema.json",
  "title": "Kugutu Character Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "character", "assets", "slots", "behaviors"],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "template"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "enum": ["avatar-lite", "mascot-upper", "vtuber-lite"]
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "propertyNames": {
        "enum": [
          "head",
          "eye.l",
          "eye.r",
          "pupil.l",
          "pupil.r",
          "brow.l",
          "brow.r",
          "nose",
          "mouth",
          "hair.front",
          "hair.back",
          "jaw",
          "neck",
          "torso",
          "upperArm.l",
          "upperArm.r",
          "forearm.l",
          "forearm.r",
          "hand.l",
          "hand.r"
        ]
      }
    },
    "parts": {
      "$ref": "#/$defs/parts"
    },
    "behaviors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "targets"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": ["blink", "look-at", "breathing", "mouth-open"]
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "params": {
            "type": "object"
          }
        }
      }
    }
  },
  "$defs": {
    "parts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog", "selections"],
      "properties": {
        "catalog": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/partCatalogItem"
          }
        },
        "selections": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/partSlot"
          },
          "additionalProperties": {
            "$ref": "#/$defs/partSelection"
          }
        }
      }
    },
    "partCatalogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slot", "asset"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slot": {
          "$ref": "#/$defs/partSlot"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          },
          "propertyNames": {
            "enum": [
              "head",
              "eye.l",
              "eye.r",
              "pupil.l",
              "pupil.r",
              "brow.l",
              "brow.r",
              "nose",
              "mouth",
              "hair.front",
              "hair.back",
              "jaw",
              "neck",
              "torso",
              "upperArm.l",
              "upperArm.r",
              "forearm.l",
              "forearm.r",
              "hand.l",
              "hand.r"
            ]
          }
        },
        "editable": {
          "type": "array",
          "items": {
            "enum": ["position", "scale", "rotation", "spacing", "color", "layer"]
          },
          "uniqueItems": true
        },
        "defaults": {
          "$ref": "#/$defs/partTransform"
        }
      }
    },
    "partSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partId"],
      "properties": {
        "partId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "transform": {
          "$ref": "#/$defs/partTransform"
        }
      }
    },
    "partTransform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number",
          "minimum": -1000,
          "maximum": 1000
        },
        "y": {
          "type": "number",
          "minimum": -1000,
          "maximum": 1000
        },
        "scale": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "scaleX": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "scaleY": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "rotation": {
          "type": "number",
          "minimum": -360,
          "maximum": 360
        },
        "spacing": {
          "type": "number",
          "minimum": -500,
          "maximum": 500
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000
        }
      }
    },
    "partSlot": {
      "enum": [
        "face",
        "hair.front",
        "hair.back",
        "eye",
        "brow",
        "nose",
        "mouth",
        "outfit"
      ]
    }
  }
}
