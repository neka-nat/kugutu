{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kugutu.dev/schema/character.schema.json",
  "title": "Kugutu Character Definition",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "character", "assets", "slots", "behaviors"],
  "properties": {
    "schemaVersion": {
      "const": "0.1.0"
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "template"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "template": {
          "type": "string",
          "enum": ["avatar-lite", "mascot-upper", "vtuber-lite"]
        }
      }
    },
    "assets": {
      "type": "object",
      "additionalProperties": false,
      "required": ["primary"],
      "properties": {
        "primary": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "slots": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "minLength": 1
      },
      "propertyNames": {
        "enum": [
          "head",
          "eye.l",
          "eye.r",
          "pupil.l",
          "pupil.r",
          "brow.l",
          "brow.r",
          "mouth",
          "jaw",
          "neck",
          "torso",
          "upperArm.l",
          "upperArm.r",
          "forearm.l",
          "forearm.r",
          "hand.l",
          "hand.r"
        ]
      }
    },
    "behaviors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "targets"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": ["blink", "look-at", "breathing", "mouth-open"]
          },
          "targets": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string"
            }
          },
          "params": {
            "type": "object"
          }
        }
      }
    }
  }
}
