{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kugutu.dev/schema/charbundle.schema.json",
  "title": "Kugutu Character Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleVersion",
    "sourceSchemaVersion",
    "character",
    "assets",
    "bindings",
    "behaviors",
    "runtime"
  ],
  "properties": {
    "bundleVersion": {
      "const": "0.1.0"
    },
    "sourceSchemaVersion": {
      "const": "0.1.0"
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "template"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "template": {
          "type": "string",
          "enum": ["avatar-lite", "mascot-upper", "vtuber-lite"]
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "const": "svg"
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slots"],
      "properties": {
        "slots": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "parts": {
      "$ref": "#/$defs/parts"
    },
    "presets": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/preset"
      }
    },
    "behaviors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "channels"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": ["blink", "look-at", "breathing", "mouth-open"]
          },
          "channels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "params": {
            "type": "object"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api"],
      "properties": {
        "api": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "applyPreset",
              "lookAt",
              "playBehavior",
              "playGesture",
              "setEmotion",
              "setMouthOpen",
              "setPart",
              "setVariant",
              "speak",
              "tunePart"
            ]
          }
        }
      }
    }
  },
  "$defs": {
    "parts": {
      "type": "object",
      "additionalProperties": false,
      "required": ["catalog", "selections"],
      "properties": {
        "catalog": {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/partCatalogItem"
          }
        },
        "selections": {
          "type": "object",
          "propertyNames": {
            "$ref": "#/$defs/partSlot"
          },
          "additionalProperties": {
            "$ref": "#/$defs/partSelection"
          }
        }
      }
    },
    "partCatalogItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "slot", "asset"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "slot": {
          "$ref": "#/$defs/partSlot"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "asset": {
          "type": "string",
          "minLength": 1
        },
        "nodes": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        },
        "editable": {
          "type": "array",
          "items": {
            "enum": ["position", "scale", "rotation", "spacing", "color", "layer"]
          },
          "uniqueItems": true
        },
        "defaults": {
          "$ref": "#/$defs/partTransform"
        }
      }
    },
    "partSelection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["partId"],
      "properties": {
        "partId": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "transform": {
          "$ref": "#/$defs/partTransform"
        }
      }
    },
    "preset": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "selections"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "selections": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "$ref": "#/$defs/partSlot"
          },
          "additionalProperties": {
            "$ref": "#/$defs/partSelection"
          }
        }
      }
    },
    "partTransform": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "x": {
          "type": "number",
          "minimum": -1000,
          "maximum": 1000
        },
        "y": {
          "type": "number",
          "minimum": -1000,
          "maximum": 1000
        },
        "scale": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "scaleX": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "scaleY": {
          "type": "number",
          "minimum": 0.01,
          "maximum": 10
        },
        "rotation": {
          "type": "number",
          "minimum": -360,
          "maximum": 360
        },
        "spacing": {
          "type": "number",
          "minimum": -500,
          "maximum": 500
        },
        "color": {
          "type": "string",
          "minLength": 1
        },
        "layer": {
          "type": "integer",
          "minimum": -1000,
          "maximum": 1000
        }
      }
    },
    "partSlot": {
      "enum": [
        "face",
        "hair.front",
        "hair.back",
        "hair.accessory",
        "eye",
        "brow",
        "nose",
        "mouth",
        "glasses",
        "beard",
        "outfit"
      ]
    }
  }
}
