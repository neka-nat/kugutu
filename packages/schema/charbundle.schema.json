{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kugutu.dev/schema/charbundle.schema.json",
  "title": "Kugutu Character Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "bundleVersion",
    "sourceSchemaVersion",
    "character",
    "assets",
    "bindings",
    "behaviors",
    "runtime"
  ],
  "properties": {
    "bundleVersion": {
      "const": "0.1.0"
    },
    "sourceSchemaVersion": {
      "const": "0.1.0"
    },
    "character": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "template"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
        },
        "template": {
          "type": "string",
          "enum": ["avatar-lite", "mascot-upper", "vtuber-lite"]
        }
      }
    },
    "assets": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "path"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "const": "svg"
          },
          "path": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "bindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["slots"],
      "properties": {
        "slots": {
          "type": "object",
          "additionalProperties": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "behaviors": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "type", "channels"],
        "properties": {
          "id": {
            "type": "string",
            "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"
          },
          "type": {
            "type": "string",
            "enum": ["blink", "look-at", "breathing", "mouth-open"]
          },
          "channels": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "params": {
            "type": "object"
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": false,
      "required": ["api"],
      "properties": {
        "api": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": ["lookAt", "playBehavior", "setEmotion", "setMouthOpen"]
          }
        }
      }
    }
  }
}
