{
  "name": "@kugutu/compiler",
  "version": "0.1.0",
  "description": "Compiles Kugutu character definitions into runtime CharBundles and CharPacks.",
  "keywords": [
    "kugutu",
    "character",
    "avatar",
    "mascot",
    "animation",
    "svg",
    "2d",
    "compiler"
  ],
  "license": "MIT",
  "author": "neka-nat <nekanat.stock@gmail.com>",
  "homepage": "https://github.com/neka-nat/kugutu#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/neka-nat/kugutu.git",
    "directory": "packages/compiler"
  },
  "bugs": "https://github.com/neka-nat/kugutu/issues",
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc -b",
    "clean": "rm -rf dist tsconfig.tsbuildinfo"
  },
  "dependencies": {
    "@kugutu/schema": "workspace:*"
  }
}
