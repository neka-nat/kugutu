{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2023", "DOM"],
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "useUnknownInCatchVariables": true,
    "rootDir": ".",
    "outDir": "dist",
    "declaration": true,
    "sourceMap": false,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "apps/**/*.d.ts",
    "apps/**/*.ts",
    "packages/**/*.ts",
    "scripts/**/*.ts"
  ]
}
