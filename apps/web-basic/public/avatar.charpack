          "asset": "parts/face/face-oval.svg",
          "editable": [
            "scale",
            "color"
          ],
          "defaults": {
            "scale": 1,
            "y": 10
          }
        },
        "eye-round": {
          "id": "eye-round",
          "slot": "eye",
          "displayName": "Round eyes",
          "asset": "parts/eye/eye-round.svg",
          "editable": [
            "scale",
            "spacing",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1,
            "spacing": 0
          }
        },
        "eye-wide": {
          "id": "eye-wide",
          "slot": "eye",
          "displayName": "Wide eyes",
          "asset": "parts/eye/eye-wide.svg",
          "editable": [
            "scale",
            "spacing",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1,
            "spacing": 0
          }
        },
        "eye-sleepy": {
          "id": "eye-sleepy",
