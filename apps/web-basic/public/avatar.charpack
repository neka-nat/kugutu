{
  "packVersion": "0.1.0",
  "bundle": {
    "bundleVersion": "0.1.0",
    "sourceSchemaVersion": "0.1.0",
    "character": {
      "id": "kugutu-mascot",
      "template": "mascot-upper"
    },
    "assets": [
      {
        "id": "primary-svg",
        "type": "svg",
        "path": "../public/avatar.svg"
      }
    ],
    "bindings": {
      "slots": {
        "head": "transform.head_group",
        "eye.l": "transform.eye_left",
        "eye.r": "transform.eye_right",
        "brow.l": "transform.brow_left",
        "brow.r": "transform.brow_right",
        "nose": "transform.nose_node",
        "mouth": "transform.mouth_group",
        "hair.front": "transform.hair_front",
        "hair.back": "transform.hair_back",
        "neck": "transform.neck_group",
        "torso": "transform.torso_group",
        "upperArm.l": "transform.upper_arm_l",
        "forearm.l": "transform.forearm_l",
        "hand.l": "transform.hand_l",
        "upperArm.r": "transform.upper_arm_r",
        "forearm.r": "transform.forearm_r",
        "hand.r": "transform.hand_r"
      }
    },
    "behaviors": [
      {
        "id": "blink-default",
        "type": "blink",
        "channels": [
          "transform.eye_left.scaleY",
          "transform.eye_right.scaleY"
        ],
        "params": {
          "closeMs": 110,
          "openMs": 130,
          "minIntervalMs": 2600,
          "maxIntervalMs": 4800
        }
      },
      {
        "id": "look-at-default",
        "type": "look-at",
        "channels": [
          "transform.eye_left.translate",
          "transform.eye_right.translate",
          "transform.head_group.rotate",
          "transform.neck_group.rotate"
        ],
        "params": {
          "radiusX": 0.16,
          "radiusY": 0.1,
          "headFollow": 0.3,
          "smoothing": 0.2
        }
      },
      {
        "id": "breathing-default",
        "type": "breathing",
        "channels": [
          "transform.torso_group.translateY",
          "transform.neck_group.translateY",
          "transform.head_group.rotate"
        ],
        "params": {
          "cycleMs": 3400,
          "amplitudeY": 0.05,
          "torsoTiltDeg": 1.2
        }
      },
      {
        "id": "mouth-open-default",
        "type": "mouth-open",
        "channels": [
          "transform.mouth_group.scaleY"
        ],
        "params": {
          "maxOpen": 0.9,
          "smoothing": 0.25
        }
      },
      {
        "id": "arm-idle-default",
        "type": "arm-idle",
        "channels": [
          "transform.upper_arm_l.rotate",
          "transform.upper_arm_r.rotate",
          "transform.forearm_l.rotate",
          "transform.forearm_r.rotate"
        ],
        "params": {
          "cycleMs": 3800,
          "swayDeg": 2.2
        }
      }
    ],
