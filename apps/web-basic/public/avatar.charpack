        "hair-front-side": {
          "id": "hair-front-side",
          "slot": "hair.front",
          "displayName": "Side swept",
          "asset": "parts/hair.front/hair-front-side.svg",
          "editable": [
            "position",
            "scale",
            "rotation",
            "color"
          ],
          "defaults": {
