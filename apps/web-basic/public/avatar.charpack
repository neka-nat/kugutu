        },
        "hair-back-none": {
          "id": "hair-back-none",
          "slot": "hair.back",
          "displayName": "None",
          "asset": "parts/hair.back/hair-back-none.svg",
          "editable": [
            "position",
            "scale",
            "rotation",
            "color"
          ],
          "defaults": {
