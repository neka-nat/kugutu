  "assets": [
    {
      "id": "primary-svg",
      "type": "svg",
      "content": "<svg\n  xmlns=\"http://www.w3.org/2000/svg\"\n  viewBox=\"0 0 320 320\"\n  fill=\"none\"\n  role=\"img\"\n>\n  <style id=\"kugutu-parts-style\">\n[data-kugutu-variant-slot=\"face\"] { display: none; }\n[data-kugutu-variant-slot=\"face\"][data-kugutu-variant-id=\"face-dev-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"hair.back\"] { display: none; }\n[data-kugutu-variant-slot=\"hair.back\"][data-kugutu-variant-id=\"hair-back-dev-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"hair.front\"] { display: none; }\n[data-kugutu-variant-slot=\"hair.front\"][data-kugutu-variant-id=\"hair-front-dev-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"eye\"] { display: none; }\n[data-kugutu-variant-slot=\"eye\"][data-kugutu-variant-id=\"eye-glasses-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"brow\"] { display: none; }\n[data-kugutu-variant-slot=\"brow\"][data-kugutu-variant-id=\"brow-dev-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"nose\"] { display: none; }\n[data-kugutu-variant-slot=\"nose\"][data-kugutu-variant-id=\"nose-soft-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"mouth\"] { display: none; }\n[data-kugutu-variant-slot=\"mouth\"][data-kugutu-variant-id=\"mouth-smirk-01\"] { display: inline; }\n[data-kugutu-variant-slot=\"outfit\"] { display: none; }\n[data-kugutu-variant-slot=\"outfit\"][data-kugutu-variant-id=\"outfit-dev-01\"] { display: inline; }\n</style>\n  <title>Kugutu Mascot Parts Prototype</title>\n\n  <g id=\"torso_group\">\n    <g data-kugutu-variant-slot=\"outfit\" data-kugutu-variant-id=\"outfit-blue-01\">\n      <path d=\"M102 260C102 230 130 219 160 219C190 219 218 230 218 260V310H102V260Z\" fill=\"#93C5FD\" />\n      <path d=\"M138 226L160 241L182 226\" stroke=\"#FFFFFF\" stroke-width=\"4\" stroke-linecap=\"round\" opacity=\"0.68\" />\n      <circle cx=\"160\" cy=\"268\" r=\"7\" fill=\"#2563EB\" opacity=\"0.8\" />\n    </g>\n\n    <g data-kugutu-variant-slot=\"outfit\" data-kugutu-variant-id=\"outfit-hoodie-01\">\n      <path d=\"M88 264C88 229 124 212 160 212C196 212 232 229 232 264V310H88V264Z\" fill=\"#6D28D9\" />\n      <path d=\"M116 230C126 216 139 208 160 208C181 208 194 216 204 230C191 224 178 222 160 222C142 222 129 224 116 230Z\" fill=\"#4C1D95\" />\n      <path d=\"M145 229L132 263\" stroke=\"#FDE68A\" stroke-width=\"5\" stroke-linecap=\"round\" />\n      <path d=\"M175 229L188 263\" stroke=\"#FDE68A\" stroke-width=\"5\" stroke-linecap=\"round\" />\n    </g>\n\n    <g data-kugutu-variant-slot=\"outfit\" data-kugutu-variant-id=\"outfit-robot-01\">\n      <path d=\"M100 260C100 228 125 212 160 212C195 212 220 228 220 260V310H100V260Z\" fill=\"#F4E8C6\" />\n      <path d=\"M112 255C112 235 132 224 160 224C188 224 208 235 208 255V310H112V255Z\" fill=\"#E6D7AC\" opacity=\"0.58\" />\n      <circle cx=\"160\" cy=\"263\" r=\"21\" fill=\"#50C7B5\" />\n      <circle cx=\"160\" cy=\"263\" r=\"12\" fill=\"#0F172A\" />\n      <circle cx=\"160\" cy=\"263\" r=\"7\" fill=\"#1F2937\" />\n    </g>\n\n    <g data-kugutu-variant-slot=\"outfit\" data-kugutu-variant-id=\"outfit-overalls-01\">\n      <path d=\"M105 254C105 226 132 218 160 218C188 218 215 226 215 254V310H105V254Z\" fill=\"#F5E7C8\" />\n      <path d=\"M117 240H203V310H117V240Z\" fill=\"#1F9A8A\" />\n      <path d=\"M130 222L143 250\" stroke=\"#D6B36A\" stroke-width=\"8\" stroke-linecap=\"round\" />\n      <path d=\"M190 222L177 250\" stroke=\"#D6B36A\" stroke-width=\"8\" stroke-linecap=\"round\" />\n      <circle cx=\"138\" cy=\"257\" r=\"6\" fill=\"#EAB308\" />\n      <circle cx=\"182\" cy=\"257\" r=\"6\" fill=\"#EAB308\" />\n    </g>\n\n    <g data-kugutu-variant-slot=\"outfit\" data-kugutu-variant-id=\"outfit-stage-01\">\n      <path d=\"M98 260C98 227 128 216 160 216C192 216 222 227 222 260V310H98V260Z\" fill=\"#1E293B\" />\n      <path d=\"M126 221L160 252L194 221L180 310H140L126 221Z\" fill=\"#FFF7ED\" />\n      <path d=\"M123 226H141V310H106V257C106 242 112 232 123 226Z\" fill=\"#B9