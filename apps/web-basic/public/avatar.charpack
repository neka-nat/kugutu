        },
        "hair-front-spiky": {
          "id": "hair-front-spiky",
          "slot": "hair.front",
          "displayName": "Spiky",
          "asset": "parts/hair.front/hair-front-spiky.svg",
          "editable": [
            "position",
            "scale",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1
          }
        },
        "hair-front-none": {
          "id": "hair-front-none",
          "slot": "hair.front",
          "displayName": "None",
          "asset": "parts/hair.front/hair-front-none.svg",
          "editable": [
            "position",
            "scale",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1
          }
        },
        "hair-back-bob": {
          "id": "hair-back-bob",
          "slot": "hair.back",
          "displayName": "Bob",
          "asset": "parts/hair.back/hair-back-bob.svg",
          "editable": [
            "position",
            "scale",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1
          }
        },
        "hair-back-long": {
          "id": "hair-back-long",
          "slot": "hair.back",
          "displayName": "Long",
          "asset": "parts/hair.back/hair-back-long.svg",
          "editable": [
            "position",
