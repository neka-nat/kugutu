          "slot": "eye",
          "displayName": "Sharp eyes",
          "asset": "parts/eye/eye-sharp.svg",
          "editable": [
            "scale",
            "spacing",
            "rotation",
            "color"
          ],
          "defaults": {
            "scale": 1,
            "spacing": 0
          }
        },
        "eye-happy": {
          "id": "eye-happy",
          "slot": "eye",
          "displayName": "Happy eyes",
          "asset": "parts/eye/eye-happy.svg",
          "editable": [
