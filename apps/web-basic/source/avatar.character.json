      "hair.back": { "partId": "hair-back-bob" },
      "hair.front": { "partId": "hair-front-bangs" },
      "eye": { "partId": "eye-round" },
      "brow": { "partId": "brow-soft" },
      "nose": { "partId": "nose-dot" },
      "mouth": { "partId": "mouth-smile" },
      "outfit": { "partId": "outfit-tee" }
    }
  },
  "behaviors": [
    {
      "id": "blink-default", "type": "blink", "targets": ["eye.l", "eye.r"],
      "params": { "closeMs": 110, "openMs": 130, "minIntervalMs": 2600, "maxIntervalMs": 4800 }
    },
    {
      "id": "look-at-default", "type": "look-at", "targets": ["eye.l", "eye.r", "head", "neck"],
      "params": { "radiusX": 0.16, "radiusY": 0.1, "headFollow": 0.3, "smoothing": 0.2 }
    },
    {
      "id": "breathing-default", "type": "breathing", "targets": ["torso", "neck", "head"],
      "params": { "cycleMs": 3400, "amplitudeY": 0.05, "torsoTiltDeg": 1.2 }
    },
    {
      "id": "mouth-open-default", "type": "mouth-open", "targets": ["mouth"],
      "params": { "maxOpen": 0.9, "smoothing": 0.25 }
    }
  ]
