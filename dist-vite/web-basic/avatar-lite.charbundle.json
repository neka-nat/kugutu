{
  "bundleVersion": "0.1.0",
  "sourceSchemaVersion": "0.1.0",
  "character": {
    "id": "kugutu-mascot",
    "template": "avatar-lite"
  },
  "assets": [
    {
      "id": "primary-svg",
      "type": "svg",
      "path": "../public/avatar.svg"
    }
  ],
  "bindings": {
    "slots": {
      "head": "transform.head_group",
      "eye.l": "transform.eye_left",
      "eye.r": "transform.eye_right",
      "brow.l": "transform.brow_left",
      "brow.r": "transform.brow_right",
      "nose": "transform.nose_node",
      "mouth": "transform.mouth_group",
      "hair.front": "transform.hair_front",
      "hair.back": "transform.hair_back",
      "neck": "transform.neck_group",
      "torso": "transform.torso_group"
    }
  },
  "behaviors": [
    {
      "id": "blink-default",
      "type": "blink",
      "channels": [
        "transform.eye_left.scaleY",
        "transform.eye_right.scaleY"
      ],
      "params": {
        "closeMs": 110,
        "openMs": 130,
        "minIntervalMs": 2600,
        "maxIntervalMs": 4800
      }
    },
    {
      "id": "look-at-default",
      "type": "look-at",
      "channels": [
        "transform.eye_left.translate",
        "transform.eye_right.translate",
        "transform.head_group.rotate",
        "transform.neck_group.rotate"
      ],
      "params": {
        "radiusX": 0.16,
        "radiusY": 0.1,
        "headFollow": 0.3,
        "smoothing": 0.2
      }
    },
    {
      "id": "breathing-default",
      "type": "breathing",
      "channels": [
        "transform.torso_group.translateY",
        "transform.neck_group.translateY",
        "transform.head_group.rotate"
      ],
      "params": {
        "cycleMs": 3400,
        "amplitudeY": 0.05,
        "torsoTiltDeg": 1.2
      }
    },
    {
      "id": "mouth-open-default",
      "type": "mouth-open",
      "channels": [
        "transform.mouth_group.scaleY"
      ],
      "params": {
        "maxOpen": 0.9,
        "smoothing": 0.25
      }
    }
  ],
  "expressions": [
    {
      "id": "happy",
      "poses": [
        {
          "slot": "brow.l",
          "rotate": -8
        },
        {
          "slot": "brow.r",
          "rotate": 8
        },
        {
          "slot": "mouth",
          "scaleY": 0.12
        }
      ]
    },
    {
      "id": "sad",
      "poses": [
        {
          "slot": "brow.l",
          "rotate": 6
        },
        {
          "slot": "brow.r",
          "rotate": -6
        }
      ]
    },
    {
      "id": "angry",
      "poses": [
        {
          "slot": "brow.l",
          "rotate": 10
        },
        {
          "slot": "brow.r",
          "rotate": -10
        }
      ]
    },
    {
      "id": "surprised",
      "poses": [
        {
          "slot": "brow.l",
          "translateY": -6
        },
        {
          "slot": "brow.r",
          "translateY": -6
        },
        {
          "slot": "mouth",
          "scaleY": 0.25
        }
      ]
    }
  ],
  "gestures": [
    {
      "id": "nod",
      "durationMs": 620,
      "tracks": [
        {
          "slot": "head",
          "keyframes": [
            {
              "t": 0,
              "translateY": 0,
              "rotate": 0
            },
            {
              "t": 0.4,
              "translateY": 8,
              "rotate": 3
            },
            {
              "t": 1,
              "translateY": 0,
              "rotate": 0
            }
          ]
        }
      ]
    },
    {
      "id": "shake",
      "durationMs": 640,
      "tracks": [
        {
          "slot": "head",
          "keyframes": [
            {
              "t": 0,
              "rotate": 0
            },
            {
              "t": 0.25,
              "rotate": -7
            },
            {
              "t": 0.5,
              "rotate": 7
            },
            {
              "t": 0.75,
              "rotate": -5
            },
            {
              "t": 1,
              "rotate": 0
            }
          ]
        }
      ]
    },
    {
      "id": "bounce",
      "durationMs": 560,
      "tracks": [
        {
          "slot": "torso",
          "keyframes": [
            {
              "t": 0,
              "translateY": 0
            },
            {
              "t": 0.45,
              "translateY": -9
            },
            {
              "t": 1,
              "translateY": 0
            }
          ]
        },
        {
          "slot": "head",
          "keyframes": [
            {
              "t": 0,
              "translateY": 0
            },
            {
              "t": 0.45,
              "translateY": -9
            },
            {
              "t": 1,
              "translateY": 0
            }
          ]
        }
      ]
    }
  ],
